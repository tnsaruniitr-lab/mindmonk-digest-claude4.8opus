# ============================================================================
#  Podcast Digest Bot — environment
#  Copy to .env and fill in. Never commit .env.
# ============================================================================

# --- Telegram -----------------------------------------------------------------
# Create a bot via @BotFather -> token. Your chat id: message @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                       # numeric id; the bot only ever talks to you

# --- Database (Railway Postgres, or any Postgres) -----------------------------
DATABASE_URL=                           # postgres://user:pass@host:port/dbname
DATABASE_SSL=false                      # true for an external/proxied URL (e.g. Railway's public URL)

# --- Primary model: insight extraction + personalization ----------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8         # cheaper option: claude-sonnet-4-6
# Per-stage model routing (Phase 1; blank = use ANTHROPIC_MODEL). Cut cost by routing
# the shared ①② extraction to a mid model and the per-delivery ④ to a cheap one.
EXTRACT_MODEL=                          # e.g. claude-sonnet-4-6
PERSONALIZE_MODEL=                      # e.g. claude-haiku-4-5

# --- Grader model: the "specified LLM" that gives the UNBIASED grade -----------
# Default targets an OpenAI-compatible endpoint (e.g. OpenRouter) so ONE key can
# reach GPT / Gemini / Llama / etc. Pick a DIFFERENT family than Anthropic above
# so the grade is a real second opinion, not self-assessment.
GRADER_PROVIDER=openai-compatible       # openai-compatible | anthropic
GRADER_API_KEY=__REPLACE_ME__           # <-- placeholder: paste your grader key
GRADER_BASE_URL=https://openrouter.ai/api/v1
GRADER_MODEL=openai/gpt-4o

# --- Transcript engine: audio -> Groq Whisper --------------------------------
# Captions get blocked on cloud IPs and don't exist for some videos, so the bot
# transcribes the AUDIO instead. yt-dlp pulls the audio (through a residential
# proxy, using a PO-token-free client) and Groq Whisper transcribes it.
GROQ_API_KEY=                            # console.groq.com — required for transcription
GROQ_MODEL=whisper-large-v3-turbo        # ~$0.04/hr of audio (free tier caps at 2h audio/hour)
YT_PROXY=                                # residential/ISP proxy: http://user:pass@host:port
YT_PLAYER_CLIENT=android_vr              # PO-token-free client that dodges SABR (swap if YT changes)

# Fallback ASR: used ONLY when Groq is rate-limited (429). Pricier (~$0.36/hr) but
# no hourly audio cap, so bursts of many long episodes still get through.
OPENAI_API_KEY=                          # platform.openai.com key (direct, not OpenRouter)
OPENAI_TRANSCRIBE_MODEL=whisper-1        # or gpt-4o-mini-transcribe (~$0.18/hr, cheaper)

# --- Transcript Tier 0: Supadata managed API (optional, recommended) --------------
# When set, tried FIRST: fetches the transcript from Supadata's infra (no proxy, no
# yt-dlp, no audio download), so it sidesteps IP blocks / SABR / 403s entirely. The
# whole audio chain above stays intact as the automatic fallback. Leave blank to skip.
SUPADATA_API_KEY=                        # supadata.ai key (sd_...)

# --- Behaviour ----------------------------------------------------------------
MIN_DURATION_MINUTES=20                 # long-form filter: skip anything shorter
POLL_CRON=*/15 * * * *                  # how often to check channels for new uploads
WORKER_CRON=*/3 * * * *                 # how often to drain the processing queue
BACKFILL_ON_ADD=1                       # process the latest episode when adding a channel
SUMMARY_LANGUAGE=English                # language the digest is written in

# --- Cost guardrail (Phase 0 kill-switch) -------------------------------------
# Hard stop on estimated daily LLM + transcription spend (USD). When today's tracked
# spend reaches this, new expensive calls pause (jobs re-queue, no data loss) until
# the next day. Generous for a single user; catches runaway loops. 0 disables it.
GLOBAL_DAILY_SPEND_CAP_USD=25
